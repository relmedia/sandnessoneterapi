# Get these from https://www.sanity.io/manage → your project
NEXT_PUBLIC_SANITY_PROJECT_ID=dgdggfdgdgdfg
NEXT_PUBLIC_SANITY_DATASET=production

# For Sanity Studio running locally (sanity dev --port 3333)
SANITY_STUDIO_PROJECT_ID=9d3bdf3u
SANITY_STUDIO_DATASET=production

# Valgfritt: hent appId fra sanity.io/manage → Studios etter første `npm run sanity:deploy`
# SANITY_STUDIO_APP_ID=your_app_id_here

# For timebestilling (Sanity → API → Tokens → Create token med Editor-tilgang)
# SANITY_API_WRITE_TOKEN=your_write_token_here

# For e-post (SMTP fra e-postleverandør / webhotell)
# SMTP_HOST=mail.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=terje@sandnessoneterapi.no
# SMTP_PASS=your_mailbox_password
# BOOKING_FROM_EMAIL="Sandnes Soneterapi <terje@sandnessoneterapi.no>"
# BOOKING_ADMIN_EMAIL=terje@example.no
# COURSE_ADMIN_EMAIL=terje@example.no

# Valgfritt for bokbestillinger (standard frakt 69 kr)
# BOOK_ADMIN_EMAIL=terje@example.no
# BOOK_SHIPPING_FEE_NOK=69

# For kurspåmelding med Vipps MobilePay (https://developer.vippsmobilepay.com/)
# VIPPS_CLIENT_ID=your_client_id
# VIPPS_CLIENT_SECRET=your_client_secret
# VIPPS_SUBSCRIPTION_KEY=your_subscription_key
# VIPPS_MERCHANT_SERIAL_NUMBER=your_msn
# VIPPS_WEBHOOK_SECRET=secret_from_webhook_registration
# VIPPS_API_BASE_URL=https://apitest.vipps.no
# VIPPS_SYSTEM_NAME=Sandnes Soneterapi

# For daglige kurspåminnelser (Vercel Cron)
# CRON_SECRET=your_random_secret_here

# Valgfritt: Cloudflare Turnstile mot bot-trafikk (https://dash.cloudflare.com/ → Turnstile)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_site_key
# TURNSTILE_SECRET_KEY=your_secret_key
# Testnøkler (alltid bestått): site 1x00000000000000000000AA, secret 1x0000000000000000000000000000000AA

# For visuell redigering og forhåndsvisning (Sanity → API → Tokens → Viewer-tilgang)
# SANITY_API_READ_TOKEN=your_read_token_here

# For øyeblikkelig oppdatering i produksjon (Sanity webhook → /api/revalidate)
# SANITY_REVALIDATE_SECRET=your_random_secret_here

# Valgfritt: brukes for metadataBase / Open Graph
NEXT_PUBLIC_SITE_URL=https://sandnessoneterapi.no
